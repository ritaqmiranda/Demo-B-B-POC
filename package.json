{
  "name": "qe-b-and-b-demo-poc",
  "version": "0.1.0",
  "private": true,
  "description": "Quality Engineering PoC for the B&B Demo availability checker and Restful Booker APIs.",
  "type": "module",
  "scripts": {
    "lint": "eslint eslint.config.js playwright.config.js pages src tests scripts/*.js",
    "lint:docs": "node scripts/check-docs.js",
    "test": "npm run test:unit && npm run test:smoke",
    "test:unit": "node --test tests/unit/**/*.test.js",
    "test:api": "playwright test tests/api",
    "test:contract": "PACT_DO_NOT_TRACK=true SCARF_NO_ANALYTICS=true playwright test tests/contract",
    "test:smoke": "playwright test --grep @smoke",
    "test:ui": "playwright test --grep @ui",
    "test:e2e": "playwright test --grep @e2e",
    "test:a11y": "playwright test --grep @accessibility",
    "test:accessibility": "npm run test:a11y",
    "test:performance": "playwright test --grep @performance",
    "test:performance:k6": "k6 run tests/non-functional/performance/k6/availability-smoke.js",
    "test:all": "playwright test",
    "test:ci": "npm run lint && npm run lint:docs && npm run test:unit && npm run test:smoke"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@eslint/js": "^9.0.0",
    "@pact-foundation/pact": "^17.0.0",
    "@playwright/test": "1.61.1",
    "eslint": "^9.0.0"
  }
}
